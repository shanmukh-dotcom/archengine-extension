{
  "name": "archengine",
  "displayName": "ArchEngine",
  "description": "Project Architecture Engine. Build Software Faster.",
  "publisher": "codecam-creator",
  "repository": {
    "type": "git",
    "url": "https://github.com/archengine/archengine"
  },
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "capabilities": {
    "workspaceTrust": {
      "supported": true,
      "description": "ArchEngine can safely scaffold projects even in restricted folders."
    }
  },
  "activationEvents": [
    "onCommand:archengine.scaffoldProject",
    "onCommand:archengine.startSession",
    "onCommand:archengine.logNote",
    "onCommand:archengine.generateResume",
    "onCommand:archengine.pushToGithub"
  ],
  "main": "./out/extension/activation.js",
  "contributes": {
    "configuration": {
      "title": "ArchEngine",
      "properties": {
        "archengine.geminiApiKey": {
          "type": "string",
          "default": "",
          "description": "API Key for Gemini (Leave blank for Pure Logic mode)"
        },
        "archengine.githubRepoUrl": {
          "type": "string",
          "default": "",
          "description": "GitHub Repository URL for this project (e.g., https://github.com/user/repo.git)"
        }
      }
    },
    "commands": [
      {
        "command": "archengine.scaffoldProject",
        "title": "ArchEngine: Generate Architecture Blueprint"
      },
      {
        "command": "archengine.startSession",
        "title": "ArchEngine: Start/Stop Coding Session"
      },
      {
        "command": "archengine.logNote",
        "title": "ArchEngine: Log Developer Note"
      },
      {
        "command": "archengine.generateResume",
        "title": "ArchEngine: Generate Developer Resume"
      },
      {
        "command": "archengine.pushToGithub",
        "title": "ArchEngine: Push to GitHub"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "18.x",
    "typescript": "^5.1.3"
  }
}
